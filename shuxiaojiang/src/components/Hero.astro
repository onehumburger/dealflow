---
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const name = lang === 'zh' ? '仓晨阳' : 'Chenyang "Arthur" Cang';
---
<section class="relative bg-gradient-to-br from-navy via-navy to-[#243656] overflow-hidden">
  <!-- Subtle pattern overlay -->
  <div class="absolute inset-0 opacity-5">
    <div class="absolute inset-0" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 40px 40px;"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-6 py-20 md:py-32">
    <div class="flex flex-col md:flex-row items-center gap-12 md:gap-16">
      <!-- Left: Text Content -->
      <div class="flex-1 text-center md:text-left">
        <p class="text-gold text-sm md:text-base font-medium tracking-wider uppercase mb-4">
          {t('hero.subtitle')}
        </p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight">
          {name}
        </h1>
        <p class="text-xl md:text-2xl text-white/70 mb-8 leading-relaxed">
          {t('hero.tagline')}
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start">
          <a href={translatePath('/contact/')} class="inline-block bg-gold text-white px-8 py-3.5 rounded-lg font-medium hover:bg-gold/90 transition-all duration-300 text-center">
            {t('hero.cta')}
          </a>
          <a href={translatePath('/about/')} class="inline-block border-2 border-white/30 text-white px-8 py-3.5 rounded-lg font-medium hover:bg-white/10 transition-all duration-300 text-center">
            {lang === 'zh' ? '了解更多' : 'Learn More'}
          </a>
        </div>
      </div>

      <!-- Right: Photo placeholder -->
      <div class="flex-shrink-0">
        <div class="w-64 h-80 md:w-72 md:h-96 rounded-2xl bg-gradient-to-b from-white/10 to-white/5 border border-white/10 flex items-center justify-center overflow-hidden shadow-2xl">
          <!-- If image exists, show it. Otherwise show initials -->
          <img
            src="/images/arthur-cang.jpg"
            alt={name}
            class="w-full h-full object-cover"
            onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
          />
          <div class="hidden items-center justify-center w-full h-full" style="display:none;">
            <span class="text-6xl font-bold text-white/20">AC</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom fade -->
  <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-white to-transparent"></div>
</section>
