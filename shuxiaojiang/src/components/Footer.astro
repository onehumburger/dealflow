---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<footer class="bg-navy text-white/80">
  <div class="h-px bg-gradient-to-r from-transparent via-gold/50 to-transparent"></div>
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Name & Title -->
      <div>
        <h3 class="text-xl font-bold text-white mb-2">
          {lang === 'zh' ? '仓晨阳' : 'Arthur Cang'}
        </h3>
        <p class="text-gold text-sm">
          {t('hero.subtitle')}
        </p>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-3">
          {t('section.contact')}
        </h4>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="mailto:arhur.cang@jingtian.com" class="hover:text-gold transition-colors duration-300">
              arhur.cang@jingtian.com
            </a>
          </li>
          <li>
            <a href="tel:+8613764513451" class="hover:text-gold transition-colors duration-300">
              (86) 137.6451.3451
            </a>
          </li>
        </ul>
      </div>

      <!-- Address -->
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-3">
          {t('contact.office')}
        </h4>
        <p class="text-sm leading-relaxed">
          {t('footer.address')}
        </p>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-10 pt-6 border-t border-white/10 text-center text-xs text-white/50">
      {t('footer.copyright')}
    </div>
  </div>
</footer>
