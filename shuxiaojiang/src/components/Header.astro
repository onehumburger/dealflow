---
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';
import LanguageToggle from './LanguageToggle.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const name = lang === 'zh' ? '仓晨阳' : 'Arthur Cang';

const navItems = [
  { label: t('nav.home'), href: translatePath('/') },
  { label: t('nav.about'), href: translatePath('/about/') },
  { label: t('nav.practice'), href: translatePath('/practice/') },
  { label: t('nav.experience'), href: translatePath('/experience/') },
  { label: t('nav.insights'), href: translatePath('/insights/') },
  { label: t('nav.contact'), href: translatePath('/contact/') },
];
---
<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100">
  <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Logo / Name -->
    <a href={translatePath('/')} class="text-xl font-bold text-navy hover:text-gold transition-colors duration-300">
      {name}
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden lg:flex items-center space-x-8">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="relative text-sm font-medium text-charcoal hover:text-navy transition-colors duration-300 py-1 after:content-[''] after:absolute after:left-0 after:bottom-0 after:w-0 after:h-0.5 after:bg-gold after:transition-all after:duration-300 hover:after:w-full"
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Right side: Language Toggle + Mobile Menu Button -->
    <div class="flex items-center space-x-4">
      <LanguageToggle />
      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden flex flex-col justify-center items-center w-8 h-8 space-y-1.5"
        aria-label="Toggle menu"
      >
        <span class="block w-6 h-0.5 bg-navy transition-all duration-300" id="hamburger-top"></span>
        <span class="block w-6 h-0.5 bg-navy transition-all duration-300" id="hamburger-mid"></span>
        <span class="block w-6 h-0.5 bg-navy transition-all duration-300" id="hamburger-bot"></span>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu Overlay -->
  <div id="mobile-menu" class="hidden lg:hidden fixed inset-0 top-16 bg-white/98 backdrop-blur-sm z-40">
    <ul class="flex flex-col items-center justify-center h-full space-y-8">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="text-2xl font-medium text-navy hover:text-gold transition-colors duration-300"
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const top = document.getElementById('hamburger-top');
  const mid = document.getElementById('hamburger-mid');
  const bot = document.getElementById('hamburger-bot');

  let isOpen = false;

  btn?.addEventListener('click', () => {
    isOpen = !isOpen;
    menu?.classList.toggle('hidden');
    if (isOpen) {
      top!.style.transform = 'rotate(45deg) translate(4px, 4px)';
      mid!.style.opacity = '0';
      bot!.style.transform = 'rotate(-45deg) translate(4px, -4px)';
    } else {
      top!.style.transform = '';
      mid!.style.opacity = '1';
      bot!.style.transform = '';
    }
  });

  // Close mobile menu on link click
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      isOpen = false;
      top!.style.transform = '';
      mid!.style.opacity = '1';
      bot!.style.transform = '';
    });
  });
</script>
