---
import { getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);

const education = [
  {
    year: '2017',
    school: { en: 'Northwestern University School of Law', zh: '西北大学法学院' },
    degree: { en: 'LL.M., American Law', zh: '法学硕士，美国法' },
    location: { en: '🇺🇸 Chicago, USA', zh: '🇺🇸 美国芝加哥' },
  },
  {
    year: '2012',
    school: { en: 'East China University of Political Science and Law', zh: '华东政法大学' },
    degree: { en: 'LL.M., International Law', zh: '法学硕士，国际法' },
    location: { en: '🇨🇳 Shanghai, China', zh: '🇨🇳 中国上海' },
  },
  {
    year: '2011',
    school: { en: 'University of Warwick School of Law', zh: '英国华威大学法学院' },
    degree: { en: 'LL.M., International Economic Law', zh: '法学硕士，国际经济法' },
    location: { en: '🇬🇧 Coventry, UK', zh: '🇬🇧 英国考文垂' },
  },
  {
    year: '2006',
    school: { en: 'East China University of Political Science and Law', zh: '华东政法大学' },
    degree: { en: 'LL.B., International Law', zh: '法学学士，国际法' },
    location: { en: '🇨🇳 Shanghai, China', zh: '🇨🇳 中国上海' },
  },
];
---
<div class="relative">
  <!-- Timeline line -->
  <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-0.5 bg-gradient-to-b from-gold via-gold/50 to-gold/20 transform md:-translate-x-1/2"></div>

  <div class="space-y-12">
    {education.map((item, index) => (
      <div class={`relative flex items-start gap-8 ${index % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
        <!-- Timeline dot -->
        <div class="absolute left-4 md:left-1/2 w-3 h-3 bg-gold rounded-full transform -translate-x-1/2 mt-2 ring-4 ring-white z-10"></div>

        <!-- Content card -->
        <div class={`ml-12 md:ml-0 md:w-[calc(50%-2rem)] ${index % 2 === 0 ? 'md:pr-8' : 'md:pl-8'}`}>
          <div class="bg-white rounded-xl p-6 shadow-md hover:shadow-lg transition-shadow duration-300 border border-gray-100">
            <span class="inline-block text-gold font-bold text-lg mb-1">{item.year}</span>
            <h3 class="text-lg font-bold text-navy mb-1">{item.school[lang]}</h3>
            <p class="text-charcoal/80 text-sm mb-1">{item.degree[lang]}</p>
            <p class="text-charcoal/50 text-xs">{item.location[lang]}</p>
          </div>
        </div>
      </div>
    ))}
  </div>
</div>
