---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import PracticeAreaCard from '../../components/PracticeAreaCard.astro';
import { getCollection } from 'astro:content';
import { useTranslations, useTranslatedPath } from '../../i18n/utils';

const lang = 'zh';
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const allPractice = await getCollection('practiceAreas');
const practice = allPractice
  .filter((p) => p.data.lang === lang)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
---
<BaseLayout>
  <Hero />

  <!-- Key Practice Areas -->
  <section class="section-container">
    <h2 class="section-title fade-in">{t('section.practice')}</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {practice.map((area) => (
        <div class="fade-in">
          <PracticeAreaCard
            title={area.data.title}
            summary={area.data.summary}
            icon={area.data.icon}
            href={translatePath('/practice/')}
          />
        </div>
      ))}
    </div>
    <div class="text-center mt-10 fade-in">
      <a href={translatePath('/practice/')} class="btn-outline">
        查看全部业务领域
      </a>
    </div>
  </section>

  <!-- About Teaser -->
  <section class="bg-lightgray">
    <div class="section-container fade-in">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="section-title">关于仓晨阳律师</h2>
        <p class="text-lg text-charcoal/80 leading-relaxed mb-8">
          执业十余年以来，仓律师已经协助数十家跨国企业在中国境内和境外拓展业务。曾于上海、英国及美国法学院接受法学教育的专业背景使仓律师拥有强烈的全球化视野。
        </p>
        <a href={translatePath('/about/')} class="btn-primary">了解更多</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-navy">
    <div class="max-w-6xl mx-auto px-6 py-16 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">需要跨境法律服务？</h2>
      <p class="text-white/70 text-lg mb-8">欢迎联系仓律师，获取专业法律建议</p>
      <a href={translatePath('/contact/')} class="inline-block bg-gold text-white px-8 py-3.5 rounded-lg font-medium hover:bg-gold/90 transition-all duration-300">
        {t('hero.cta')}
      </a>
    </div>
  </section>
</BaseLayout>
