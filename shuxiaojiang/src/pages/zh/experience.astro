---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

const lang = 'zh';

const expEntries = await getCollection('experience');
const expEntry = expEntries.find((e) => e.data.lang === lang);
const { Content } = expEntry ? await render(expEntry) : { Content: null };
---
<BaseLayout title="代表案例 | 仓晨阳律师">
  <!-- Page Header -->
  <section class="bg-gradient-to-br from-navy via-navy/95 to-navy/90">
    <div class="max-w-6xl mx-auto px-6 py-20 md:py-28 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">代表案例</h1>
      <p class="text-white/70 text-lg md:text-xl">跨境投资并购领域精选案例</p>
    </div>
  </section>

  <!-- Experience Content -->
  <section class="section-container">
    <div class="card fade-in p-8 md:p-12">
      {Content && (
        <div class="prose prose-lg max-w-none prose-headings:text-navy prose-headings:border-b prose-headings:border-gold/20 prose-headings:pb-3 prose-headings:mb-6 prose-li:text-charcoal/80">
          <Content />
        </div>
      )}
    </div>
  </section>
</BaseLayout>
