---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import GlobeIcon from '../../components/icons/GlobeIcon.astro';
import DiamondIcon from '../../components/icons/DiamondIcon.astro';
import CloudIcon from '../../components/icons/CloudIcon.astro';
import FilmIcon from '../../components/icons/FilmIcon.astro';
import BuildingIcon from '../../components/icons/BuildingIcon.astro';
import StoreIcon from '../../components/icons/StoreIcon.astro';
import GamepadIcon from '../../components/icons/GamepadIcon.astro';
import ScaleIcon from '../../components/icons/ScaleIcon.astro';

const lang = 'zh';

const allPractice = await getCollection('practiceAreas');
const practiceItems = allPractice
  .filter((p) => p.data.lang === lang)
  .sort((a, b) => a.data.order - b.data.order);

const renderedItems = await Promise.all(
  practiceItems.map(async (item) => {
    const { Content } = await render(item);
    return { ...item, Content };
  })
);

const iconComponents: Record<string, any> = {
  globe: GlobeIcon,
  diamond: DiamondIcon,
  cloud: CloudIcon,
  film: FilmIcon,
  building: BuildingIcon,
  store: StoreIcon,
  gamepad: GamepadIcon,
};
---
<BaseLayout title="业务领域 | 仓晨阳律师">
  <!-- Page Header -->
  <section class="bg-gradient-to-br from-navy via-navy/95 to-navy/90">
    <div class="max-w-6xl mx-auto px-6 py-20 md:py-28 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">业务领域</h1>
      <p class="text-white/70 text-lg md:text-xl">为客户提供全方位的跨境法律服务</p>
    </div>
  </section>

  <!-- Practice Areas Grid -->
  <section class="section-container">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {renderedItems.map((item) => {
        const IconComponent = iconComponents[item.data.icon] || ScaleIcon;
        return (
          <div class="card fade-in">
            <div class="mb-3">
              <IconComponent />
            </div>
            <h3 class="text-xl font-bold text-navy mb-2">{item.data.title}</h3>
            <p class="text-charcoal/60 text-sm mb-4">{item.data.summary}</p>
            <div class="prose prose-sm max-w-none text-charcoal/70">
              <item.Content />
            </div>
          </div>
        );
      })}
    </div>
  </section>
</BaseLayout>
