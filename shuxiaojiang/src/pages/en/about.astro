---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EducationTimeline from '../../components/EducationTimeline.astro';
import DocumentIcon from '../../components/icons/DocumentIcon.astro';
import { getCollection, render } from 'astro:content';
import { useTranslations } from '../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);

const aboutEntries = await getCollection('about');
const aboutEntry = aboutEntries.find((e) => e.data.lang === lang);
const { Content } = aboutEntry ? await render(aboutEntry) : { Content: null };

const publications = [
  'Contributor, Report on the Regulations for Adoption of Cloud in the Healthcare Sector, Asia Cloud Computing Association (2016)',
  'Contributor, "Ready for the Cloud: A Report on FSI Regulations Impacting Cloud in Asia Pacific Markets," Asia Cloud Computing Association (2015)',
  'Contributor, "The Impact of Data Sovereignty on Cloud Computing in Asia," Asia Cloud Computing Association (2013)',
];

const memberships = [
  'Member, Shanghai Bar Association',
  'Member, China Democratic and Nation Building Committee',
];
---
<BaseLayout title="About Arthur Cang | Jingtian & Gongcheng">
  <section class="bg-gradient-to-br from-navy to-[#243656] py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">About Arthur Cang</h1>
      <p class="text-gold text-lg">Jingtian & Gongcheng · Partner · Shanghai Office</p>
    </div>
  </section>

  <section class="section-container">
    <div class="max-w-3xl mx-auto">
      <div class="prose prose-lg prose-navy max-w-none text-charcoal/80 leading-relaxed fade-in">
        {Content && <Content />}
      </div>
    </div>
  </section>

  <section class="bg-lightgray">
    <div class="section-container">
      <h2 class="section-title fade-in">{t('about.education')}</h2>
      <div class="fade-in">
        <EducationTimeline />
      </div>
    </div>
  </section>

  <section class="section-container">
    <h2 class="section-title fade-in">{t('about.publications')}</h2>
    <div class="max-w-3xl mx-auto fade-in">
      <ul class="space-y-4">
        {publications.map((pub) => (
          <li class="flex items-start gap-3 p-4 bg-white rounded-lg shadow-sm border border-gray-100">
            <span class="mt-0.5 flex-shrink-0"><DocumentIcon /></span>
            <span class="text-charcoal/80">{pub}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="bg-lightgray">
    <div class="section-container">
      <h2 class="section-title fade-in">{t('about.memberships')}</h2>
      <div class="max-w-3xl mx-auto fade-in">
        <ul class="space-y-4">
          {memberships.map((m) => (
            <li class="flex items-start gap-3 p-4 bg-white rounded-lg shadow-sm border border-gray-100">
              <span class="text-gold mt-1 flex-shrink-0">•</span>
              <span class="text-charcoal/80">{m}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
