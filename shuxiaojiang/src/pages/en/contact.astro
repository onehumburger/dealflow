---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/utils';
import EnvelopeIcon from '../../components/icons/EnvelopeIcon.astro';
import PhoneIcon from '../../components/icons/PhoneIcon.astro';
import OfficeIcon from '../../components/icons/OfficeIcon.astro';
import ChatIcon from '../../components/icons/ChatIcon.astro';

const lang = 'en';
const t = useTranslations(lang);
---
<BaseLayout title="Contact | Arthur Cang">
  <section class="bg-gradient-to-br from-navy to-[#243656] py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Contact</h1>
      <p class="text-gold text-lg">Get in touch for professional legal advice</p>
    </div>
  </section>

  <section class="section-container">
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Email -->
        <div class="card fade-in text-center">
          <div class="flex justify-center mb-4">
            <EnvelopeIcon />
          </div>
          <h3 class="text-lg font-bold text-navy mb-2">{t('contact.email')}</h3>
          <a href="mailto:arhur.cang@jingtian.com" class="text-gold hover:underline">
            arhur.cang@jingtian.com
          </a>
        </div>

        <!-- Phone -->
        <div class="card fade-in text-center">
          <div class="flex justify-center mb-4">
            <PhoneIcon />
          </div>
          <h3 class="text-lg font-bold text-navy mb-2">{t('contact.phone')}</h3>
          <a href="tel:+8613764513451" class="text-gold hover:underline">
            (86) 137.6451.3451
          </a>
        </div>

        <!-- Office -->
        <div class="card fade-in text-center">
          <div class="flex justify-center mb-4">
            <OfficeIcon />
          </div>
          <h3 class="text-lg font-bold text-navy mb-2">{t('contact.office')}</h3>
          <p class="text-charcoal/70">
            {t('footer.address')}
          </p>
        </div>

        <!-- WeChat -->
        <div class="card fade-in text-center">
          <div class="flex justify-center mb-4">
            <ChatIcon />
          </div>
          <h3 class="text-lg font-bold text-navy mb-2">{t('contact.wechat')}</h3>
          <div class="w-32 h-32 mx-auto bg-lightgray rounded-lg flex items-center justify-center text-charcoal/30 text-sm border-2 border-dashed border-gray-300">
            WeChat QR Code
          </div>
        </div>
      </div>

      <!-- Firm link -->
      <div class="text-center mt-12 fade-in">
        <p class="text-charcoal/60 mb-4">Learn more about Jingtian & Gongcheng</p>
        <a href="https://www.jingtian.com" target="_blank" rel="noopener noreferrer" class="btn-outline">
          Visit Jingtian & Gongcheng ↗
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
