---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { useTranslations, useTranslatedPath } from '../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const allInsights = await getCollection('insights');
const insights = allInsights
  .filter((i) => i.data.lang === lang)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<BaseLayout title="Insights | Arthur Cang">
  <section class="bg-gradient-to-br from-navy to-[#243656] py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Insights</h1>
      <p class="text-gold text-lg">Industry Analysis & Legal Commentary</p>
    </div>
  </section>

  <section class="section-container">
    {insights.length === 0 ? (
      <div class="text-center py-16">
        <div class="text-6xl mb-6 opacity-30">📝</div>
        <p class="text-xl text-charcoal/50">{t('insights.empty')}</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {insights.map((post) => (
          <article class="card fade-in">
            <time class="text-sm text-gold font-medium">
              {post.data.date.toLocaleDateString('en-US')}
            </time>
            <h2 class="text-xl font-bold text-navy mt-2 mb-3">{post.data.title}</h2>
            <p class="text-charcoal/70 text-sm mb-4">{post.data.summary}</p>
            {post.data.tags && (
              <div class="flex flex-wrap gap-2 mb-4">
                {post.data.tags.map((tag) => (
                  <span class="text-xs bg-lightgray text-charcoal/60 px-2 py-1 rounded">{tag}</span>
                ))}
              </div>
            )}
            <a
              href={`${translatePath('/insights/')}${post.id.replace(/^en\//, '')}/`}
              class="text-gold font-medium text-sm hover:underline"
            >
              {t('insights.readmore')} →
            </a>
          </article>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
