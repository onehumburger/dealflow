---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const allInsights = await getCollection('insights');
  return allInsights
    .filter((i) => i.data.lang === 'en')
    .map((post) => ({
      params: { slug: post.id.replace(/^en\//, '') },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<BaseLayout title={`${post.data.title} | Arthur Cang`}>
  <section class="bg-gradient-to-br from-navy to-[#243656] py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">{post.data.title}</h1>
      <time class="text-gold">{post.data.date.toLocaleDateString('en-US')}</time>
    </div>
  </section>

  <section class="section-container">
    <div class="max-w-3xl mx-auto">
      <div class="prose prose-lg max-w-none prose-headings:text-navy prose-a:text-gold">
        <Content />
      </div>
      <div class="mt-12 pt-6 border-t border-gray-200">
        <a href="/en/insights/" class="text-gold font-medium hover:underline">&larr; Back to Insights</a>
      </div>
    </div>
  </section>
</BaseLayout>
